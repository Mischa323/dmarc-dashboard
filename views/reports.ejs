<div class="d-flex align-items-center mb-3 gap-3">
  <h4 class="mb-0 fw-bold">Reports</h4>
  <form class="d-flex gap-2 ms-auto" method="get">
    <input type="text" name="domain" class="form-control form-control-sm"
           placeholder="Filter by domain" value="<%= activeFilters.domain %>">
    <button type="submit" class="btn btn-sm btn-outline-secondary">Filter</button>
    <% if (Object.values(activeFilters).some(v => v)) { %>
    <a href="/reports" class="btn btn-sm btn-outline-danger">Clear all</a>
    <% } %>
  </form>
</div>

<% if (Object.values(activeFilters).some(v => v)) { %>
<div class="d-flex flex-wrap gap-2 mb-3">
  <% if (activeFilters.status) { %>
  <% const statusParams = new URLSearchParams(filterQuery); statusParams.delete('status'); %>
  <span class="badge d-flex align-items-center gap-1 px-2 py-1"
        style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);font-size:.8rem;">
    Status: <%= activeFilters.status %>
    <a href="/reports?<%= statusParams.toString() %>" class="text-secondary ms-1" style="line-height:1;">&times;</a>
  </span>
  <% } %>
  <% if (activeFilters.date) { %>
  <% const dateParams = new URLSearchParams(filterQuery); dateParams.delete('date'); %>
  <span class="badge d-flex align-items-center gap-1 px-2 py-1"
        style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);font-size:.8rem;">
    Date: <%= activeFilters.date %>
    <a href="/reports?<%= dateParams.toString() %>" class="text-secondary ms-1" style="line-height:1;">&times;</a>
  </span>
  <% } %>
  <% if (activeFilters.ip) { %>
  <% const ipParams = new URLSearchParams(filterQuery); ipParams.delete('ip'); %>
  <span class="badge d-flex align-items-center gap-1 px-2 py-1"
        style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);font-size:.8rem;">
    IP: <%= activeFilters.ip %>
    <a href="/reports?<%= ipParams.toString() %>" class="text-secondary ms-1" style="line-height:1;">&times;</a>
  </span>
  <% } %>
  <% if (activeFilters.org) { %>
  <% const orgParams = new URLSearchParams(filterQuery); orgParams.delete('org'); %>
  <span class="badge d-flex align-items-center gap-1 px-2 py-1"
        style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);font-size:.8rem;">
    Org: <%= activeFilters.org %>
    <a href="/reports?<%= orgParams.toString() %>" class="text-secondary ms-1" style="line-height:1;">&times;</a>
  </span>
  <% } %>
  <% if (activeFilters.domain) { %>
  <% const domainParams = new URLSearchParams(filterQuery); domainParams.delete('domain'); %>
  <span class="badge d-flex align-items-center gap-1 px-2 py-1"
        style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);font-size:.8rem;">
    Domain: <%= activeFilters.domain %>
    <a href="/reports?<%= domainParams.toString() %>" class="text-secondary ms-1" style="line-height:1;">&times;</a>
  </span>
  <% } %>
  <small class="text-secondary align-self-center"><%= total %> result<%= total !== 1 ? 's' : '' %></small>
</div>
<% } %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th>Domain</th>
          <th>Reporter</th>
          <th>Period end</th>
          <th class="text-end">Messages</th>
          <th class="text-end">Passed</th>
          <th class="text-end">Failed</th>
          <th class="text-end">Pass rate</th>
          <th>Policy</th>
        </tr>
      </thead>
      <tbody>
        <% if (reports.length === 0) { %>
        <tr><td colspan="8" class="text-center text-secondary py-5">
          No reports yet. Use <strong>Fetch now</strong> or configure the scheduler.
        </td></tr>
        <% } %>
        <% for (const report of reports) { %>
        <tr onclick="window.location='/reports/<%= report.id %>'" style="cursor:pointer">
          <td>
            <span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:<%= domainColors[report.domain] || 'rgba(255,255,255,.25)' %>;margin-right:7px;vertical-align:middle;flex-shrink:0;"></span>
            <a href="/reports/<%= report.id %>" class="fw-semibold text-decoration-none"><%= report.domain %></a>
          </td>
          <td class="text-secondary small"><%= report.org_name || '—' %></td>
          <td class="text-secondary small"><%= report.end_date ? report.end_date.slice(0, 10) : '—' %></td>
          <td class="text-end"><%= report.total_messages %></td>
          <td class="text-end pass-color"><%= report.passed_messages %></td>
          <td class="text-end fail-color"><%= report.failed_messages %></td>
          <td class="text-end">
            <span class="badge px-2 py-1 <%=
              report.pass_rate >= 98 ? 'badge-pass' :
              report.pass_rate >= 90 ? 'text-warning bg-warning bg-opacity-10' :
              'badge-fail'
            %>"><%= report.pass_rate %>%</span>
          </td>
          <td><code class="small"><%= report.policy_p || '—' %></code></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination pagination-sm justify-content-center">
    <% const pgBase = filterQuery ? '?' + filterQuery + '&page=' : '?page='; %>
    <% if (page > 1) { %>
    <li class="page-item">
      <a class="page-link" href="<%= pgBase %><%= page - 1 %>">Previous</a>
    </li>
    <% } %>
    <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
    <li class="page-item <%= p === page ? 'active' : '' %>">
      <a class="page-link" href="<%= pgBase %><%= p %>"><%= p %></a>
    </li>
    <% } %>
    <% if (page < totalPages) { %>
    <li class="page-item">
      <a class="page-link" href="<%= pgBase %><%= page + 1 %>">Next</a>
    </li>
    <% } %>
  </ul>
</nav>
<% } %>
