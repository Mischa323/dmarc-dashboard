<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Two-factor authentication — DMARC Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <style>
    body { background: #0d1117; color: #e6edf3; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 12px; max-width: 380px; width: 100%; padding: 2.5rem; }
    .form-control { background: #0d1117; border-color: #30363d; color: #e6edf3; letter-spacing: .35em; font-size: 1.5rem; text-align: center; }
    .form-control:focus { background: #0d1117; border-color: #58a6ff; color: #e6edf3; box-shadow: 0 0 0 3px rgba(88,166,255,.15); }
    .form-control::placeholder { letter-spacing: normal; font-size: 1rem; color: #484f58; }
    a { color: #58a6ff; }
  </style>
</head>
<body>
  <div class="card m-3 text-center">
    <i class="bi bi-shield-lock text-success mb-3" style="font-size:2.5rem;"></i>
    <h5 class="fw-bold mb-1">Two-factor authentication</h5>
    <p class="text-secondary small mb-4">
      Open your authenticator app and enter the 6-digit code for <strong>DMARC Dashboard</strong>.
    </p>

    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3">
      <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
      <span><%= error %></span>
    </div>
    <% } %>

    <form method="post" action="/auth/2fa" autocomplete="off">
      <div class="mb-4">
        <input type="text" class="form-control" name="token"
               placeholder="000 000"
               maxlength="7"
               inputmode="numeric"
               pattern="[0-9 ]{6,7}"
               autofocus required />
      </div>
      <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">Verify</button>
    </form>

    <a href="/auth/login" class="d-block mt-3 small text-secondary">← Back to login</a>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Auto-submit when 6 digits entered
    const input = document.querySelector('input[name="token"]');
    input.addEventListener('input', () => {
      const digits = input.value.replace(/\D/g, '');
      if (digits.length === 6) {
        input.value = digits;
        input.form.submit();
      }
    });
  </script>
</body>
</html>
