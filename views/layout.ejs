<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || 'DMARC Dashboard' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

  <!-- Apply saved theme before paint to avoid flash -->
  <script>
    (function () {
      const DEFAULTS = {
        '--clr-accent':     '#0a84ff', '--clr-accent-rgb':  '10,132,255',
        '--clr-pass':       '#30d158', '--clr-pass-rgb':    '48,209,88',
        '--clr-fail':       '#ff453a', '--clr-fail-rgb':    '255,69,58',
        '--clr-warn':       '#ff9f0a', '--clr-warn-rgb':    '255,159,10',
        '--bg-orb1': 'rgba(94,60,255,0.22)', '--bg-orb2': 'rgba(10,132,255,0.18)',
      };
      try {
        const saved = JSON.parse(localStorage.getItem('dmarc-theme') || '{}');
        const vars = Object.assign({}, DEFAULTS, saved);
        const r = document.documentElement;
        Object.entries(vars).forEach(([k, v]) => r.style.setProperty(k, v));
      } catch (e) {}
    })();
  </script>

  <style>
    /* ── CSS Variables ─────────────────────────────────────────────────────── */
    :root {
      --clr-accent:     #0a84ff;
      --clr-accent-rgb: 10, 132, 255;
      --clr-pass:       #30d158;
      --clr-pass-rgb:   48, 209, 88;
      --clr-fail:       #ff453a;
      --clr-fail-rgb:   255, 69, 58;
      --clr-warn:       #ff9f0a;
      --clr-warn-rgb:   255, 159, 10;
      --bg-orb1: rgba(94, 60, 255, 0.22);
      --bg-orb2: rgba(10, 132, 255, 0.18);
    }

    /* ── Base ─────────────────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }

    body {
      background:
        radial-gradient(ellipse 70% 55% at 12% 10%, var(--bg-orb1) 0%, transparent 65%),
        radial-gradient(ellipse 55% 45% at 88% 85%, var(--bg-orb2) 0%, transparent 65%),
        radial-gradient(ellipse 50% 40% at 55% 50%, rgba(30, 10, 60, 0.5) 0%, transparent 80%),
        #000;
      background-attachment: fixed;
      color: rgba(255, 255, 255, 0.88);
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ── Navbar ───────────────────────────────────────────────────────────── */
    .app-nav {
      background: rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(40px) saturate(220%);
      -webkit-backdrop-filter: blur(40px) saturate(220%);
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      position: sticky;
      top: 0;
      z-index: 1030;
    }
    .navbar-brand { font-weight: 650; letter-spacing: -0.2px; color: rgba(255,255,255,.95) !important; }
    .nav-link { color: rgba(255,255,255,.6) !important; font-size: .875rem; border-radius: 8px; padding: .32rem .62rem !important; transition: color .14s, background .14s; }
    .nav-link:hover { color: rgba(255,255,255,.92) !important; background: rgba(255,255,255,.07); }
    .nav-link.active { color: rgba(255,255,255,.95) !important; }
    .navbar-toggler { border-color: rgba(255,255,255,.15); }

    /* ── Glass cards ──────────────────────────────────────────────────────── */
    .card {
      background: rgba(255,255,255,.055);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      border: 1px solid rgba(255,255,255,.09) !important;
      border-radius: 18px !important;
      box-shadow: 0 2px 24px rgba(0,0,0,.38), inset 0 1px 0 rgba(255,255,255,.06);
      transition: box-shadow .2s, border-color .2s;
    }
    .card:hover { box-shadow: 0 4px 36px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.09); }
    .card-pass {
      background: rgba(var(--clr-pass-rgb), .06) !important;
      border-color: rgba(var(--clr-pass-rgb), .28) !important;
    }
    .card-fail {
      background: rgba(var(--clr-fail-rgb), .06) !important;
      border-color: rgba(var(--clr-fail-rgb), .28) !important;
    }
    .card-warn {
      background: rgba(var(--clr-warn-rgb), .06) !important;
      border-color: rgba(var(--clr-warn-rgb), .28) !important;
    }

    /* ── Tables ───────────────────────────────────────────────────────────── */
    .table { color: rgba(255,255,255,.82); --bs-table-bg: transparent; --bs-table-hover-bg: rgba(255,255,255,.035); --bs-table-border-color: rgba(255,255,255,.05); }
    .table th { color: rgba(255,255,255,.36); font-weight: 500; font-size: .76rem; text-transform: uppercase; letter-spacing: .07em; border-bottom: 1px solid rgba(255,255,255,.07) !important; padding-top: .85rem; padding-bottom: .65rem; }
    .table td { border-color: rgba(255,255,255,.04); vertical-align: middle; }
    .table-responsive { border-radius: 17px; overflow: hidden; }

    /* ── Buttons ──────────────────────────────────────────────────────────── */
    .btn { border-radius: 10px; font-size: .84rem; font-weight: 500; letter-spacing: .01em; transition: all .15s; }
    .btn-sm { border-radius: 8px; }
    .btn-success { background: linear-gradient(145deg, color-mix(in srgb, var(--clr-pass) 85%, #fff 15%), color-mix(in srgb, var(--clr-pass) 75%, #000 25%)); border: none; color: #fff; box-shadow: 0 2px 12px rgba(var(--clr-pass-rgb),.32); }
    .btn-success:hover { box-shadow: 0 4px 20px rgba(var(--clr-pass-rgb),.44); color: #fff; }
    .btn-outline-success { background: rgba(var(--clr-pass-rgb),.07); border-color: rgba(var(--clr-pass-rgb),.35); color: var(--clr-pass); }
    .btn-outline-success:hover { background: rgba(var(--clr-pass-rgb),.15); border-color: rgba(var(--clr-pass-rgb),.55); color: var(--clr-pass); }
    .btn-outline-secondary { background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.13); color: rgba(255,255,255,.62); }
    .btn-outline-secondary:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.22); color: rgba(255,255,255,.9); }
    .btn-outline-primary { background: rgba(var(--clr-accent-rgb),.07); border-color: rgba(var(--clr-accent-rgb),.35); color: var(--clr-accent); }
    .btn-outline-primary:hover { background: rgba(var(--clr-accent-rgb),.15); border-color: rgba(var(--clr-accent-rgb),.55); color: var(--clr-accent); }
    .btn-outline-warning { background: rgba(var(--clr-warn-rgb),.07); border-color: rgba(var(--clr-warn-rgb),.35); color: var(--clr-warn); }
    .btn-outline-warning:hover { background: rgba(var(--clr-warn-rgb),.14); color: var(--clr-warn); }
    .btn-outline-danger { background: rgba(var(--clr-fail-rgb),.06); border-color: rgba(var(--clr-fail-rgb),.3); color: var(--clr-fail); }
    .btn-outline-danger:hover { background: rgba(var(--clr-fail-rgb),.14); border-color: rgba(var(--clr-fail-rgb),.5); color: var(--clr-fail); }
    .btn-link { color: rgba(255,255,255,.42); text-decoration: none; }
    .btn-link:hover { color: rgba(255,255,255,.7); }

    /* ── Form controls ────────────────────────────────────────────────────── */
    .form-control, .form-select { background: rgba(255,255,255,.065); border: 1px solid rgba(255,255,255,.1); border-radius: 10px; color: rgba(255,255,255,.9); transition: border-color .14s, box-shadow .14s, background .14s; }
    .form-control::placeholder { color: rgba(255,255,255,.25); }
    .form-control:focus, .form-select:focus { background: rgba(255,255,255,.09); border-color: rgba(var(--clr-accent-rgb),.7); box-shadow: 0 0 0 3px rgba(var(--clr-accent-rgb),.18); color: rgba(255,255,255,.95); outline: none; }
    .form-control-sm, .form-select-sm { border-radius: 8px; }
    .form-select option { background: #1c1c1e; color: #fff; }
    .form-label { color: rgba(255,255,255,.72); font-size: .85rem; font-weight: 500; }
    .form-text { color: rgba(255,255,255,.36); font-size: .79rem; }
    .form-check-input { background-color: rgba(255,255,255,.09); border-color: rgba(255,255,255,.2); border-radius: 5px; }
    .form-check-input:checked { background-color: var(--clr-accent); border-color: var(--clr-accent); }
    .form-check-input:focus { box-shadow: 0 0 0 3px rgba(var(--clr-accent-rgb),.22); }
    .form-switch .form-check-input { border-radius: 12px; }
    .form-check-label { color: rgba(255,255,255,.7); font-size: .86rem; }
    .input-group-text { background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.1); color: rgba(255,255,255,.38); border-radius: 10px; }

    /* ── Badges ───────────────────────────────────────────────────────────── */
    .badge { border-radius: 7px; font-weight: 500; letter-spacing: .02em; }
    .badge-pass { background: rgba(var(--clr-pass-rgb),.14); color: var(--clr-pass); border: 1px solid rgba(var(--clr-pass-rgb),.24); }
    .badge-fail { background: rgba(var(--clr-fail-rgb),.14); color: var(--clr-fail); border: 1px solid rgba(var(--clr-fail-rgb),.24); }

    /* ── Alerts ───────────────────────────────────────────────────────────── */
    .alert-success { background: rgba(var(--clr-pass-rgb),.1); border: 1px solid rgba(var(--clr-pass-rgb),.22); color: var(--clr-pass); border-radius: 13px; }
    .alert-danger   { background: rgba(var(--clr-fail-rgb),.1); border: 1px solid rgba(var(--clr-fail-rgb),.22); color: var(--clr-fail); border-radius: 13px; }
    .alert-warning  { background: rgba(var(--clr-warn-rgb),.09); border: 1px solid rgba(var(--clr-warn-rgb),.2); color: var(--clr-warn); border-radius: 13px; }
    .btn-close-white { filter: invert(1) opacity(.6); }

    /* ── Dropdowns ────────────────────────────────────────────────────────── */
    .dropdown-menu { background: rgba(22,22,28,.88); backdrop-filter: blur(32px) saturate(200%); -webkit-backdrop-filter: blur(32px) saturate(200%); border: 1px solid rgba(255,255,255,.1); border-radius: 14px; box-shadow: 0 8px 40px rgba(0,0,0,.55); padding: .35rem; }
    .dropdown-item { color: rgba(255,255,255,.78); border-radius: 9px; font-size: .875rem; padding: .42rem .72rem; transition: background .1s; }
    .dropdown-item:hover { background: rgba(255,255,255,.08); color: #fff; }
    .dropdown-item.text-danger { color: var(--clr-fail) !important; }
    .dropdown-item.text-danger:hover { background: rgba(var(--clr-fail-rgb),.1); }
    .dropdown-divider { border-color: rgba(255,255,255,.07); margin: .28rem .45rem; }

    /* ── Modals ───────────────────────────────────────────────────────────── */
    .modal-content { background: rgba(18,18,24,.92) !important; backdrop-filter: blur(40px) saturate(200%); -webkit-backdrop-filter: blur(40px) saturate(200%); border: 1px solid rgba(255,255,255,.09) !important; border-radius: 20px !important; box-shadow: 0 24px 80px rgba(0,0,0,.7); }
    .modal-header { border-color: rgba(255,255,255,.07) !important; }
    .modal-backdrop.show { opacity: .55; }

/* ── Misc ─────────────────────────────────────────────────────────────── */
    a { color: var(--clr-accent); }
    a:hover { color: color-mix(in srgb, var(--clr-accent) 70%, #fff 30%); }
    .pass-color { color: var(--clr-pass); }
    .fail-color { color: var(--clr-fail); }
    .text-secondary { color: rgba(255,255,255,.42) !important; }
    .text-muted { color: rgba(255,255,255,.35) !important; }
    .chart-container { position: relative; height: 300px; }
    code { background: rgba(255,255,255,.08); border-radius: 6px; padding: .1em .38em; color: rgba(255,255,255,.72); font-size: .84em; }
    hr { border-color: rgba(255,255,255,.07); }
    strong { color: rgba(255,255,255,.9); font-weight: 600; }
    .fw-semibold { font-weight: 580; }
    .border-danger { border-color: rgba(var(--clr-fail-rgb),.28) !important; }

    /* ── Scrollbar ────────────────────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.14); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.24); }
  </style>
</head>
<body>
  <nav class="app-nav navbar navbar-expand-lg">
    <div class="container-fluid px-4">
      <a class="navbar-brand" href="/"><i class="bi bi-shield-check me-2 text-success"></i>DMARC Dashboard</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMain">
        <ul class="navbar-nav me-auto gap-1">
          <li class="nav-item">
            <a class="nav-link <%= locals.path === '/' ? 'active' : '' %>" href="/">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= locals.path && locals.path.startsWith('/reports') ? 'active' : '' %>" href="/reports">Reports</a>
          </li>
          <% if (locals.user && (user.role === 'local_admin' || user.role === 'admin')) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle <%= locals.path && locals.path.startsWith('/admin') ? 'active' : '' %>"
               href="#" data-bs-toggle="dropdown">Admin</a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/admin"><i class="bi bi-speedometer2 me-2"></i>Overview</a></li>
              <li><a class="dropdown-item" href="/admin/tenants"><i class="bi bi-buildings me-2"></i>Tenants</a></li>
              <li><a class="dropdown-item" href="/admin/users"><i class="bi bi-people me-2"></i>Users</a></li>
              <% if (locals.user && user.role === 'local_admin') { %>
              <li><hr class="dropdown-divider" /></li>
              <li><a class="dropdown-item" href="/admin/settings"><i class="bi bi-sliders me-2"></i>Settings</a></li>
              <li><a class="dropdown-item" href="/admin/2fa"><i class="bi bi-shield-lock me-2"></i>Two-factor auth</a></li>
              <li><a class="dropdown-item text-danger" href="/admin/danger"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</a></li>
              <% } %>
            </ul>
          </li>
          <% } %>
        </ul>

        <div class="d-flex align-items-center gap-2">
          <button class="btn btn-sm btn-outline-secondary" id="fetchBtn" onclick="triggerFetch()">
            <i class="bi bi-arrow-clockwise me-1"></i>Fetch now
          </button>

<% if (locals.user) { %>
          <span class="text-secondary small d-none d-lg-inline" style="font-size:.82rem;">
            <i class="bi bi-person-circle me-1"></i><%= user.name %>
            <% if (user.role === 'local_admin') { %>
            <span class="badge ms-1" style="background:rgba(var(--clr-warn-rgb),.1);color:var(--clr-warn);border:1px solid rgba(var(--clr-warn-rgb),.2);font-size:.68rem;">local admin</span>
            <% } else if (user.role === 'admin') { %>
            <span class="badge ms-1" style="background:rgba(var(--clr-accent-rgb),.1);color:var(--clr-accent);border:1px solid rgba(var(--clr-accent-rgb),.2);font-size:.68rem;">admin</span>
            <% } %>
          </span>
          <a href="/auth/logout" class="btn btn-sm btn-outline-danger">Sign out</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4 px-4">
    <%- body %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <script>
    Chart.defaults.color = 'rgba(255,255,255,0.38)';
    Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';

    // ── Theme system ────────────────────────────────────────────────────────
    const PRESET_THEMES = {
      cosmic:   { orb1:'rgba(94,60,255,0.22)',   orb2:'rgba(10,132,255,0.18)',  accent:'#0a84ff', accentRgb:'10,132,255' },
      ocean:    { orb1:'rgba(0,150,200,0.22)',    orb2:'rgba(0,220,180,0.18)',   accent:'#00c7be', accentRgb:'0,199,190' },
      midnight: { orb1:'rgba(60,0,200,0.25)',     orb2:'rgba(155,93,229,0.2)',   accent:'#9b5de5', accentRgb:'155,93,229' },
      ember:    { orb1:'rgba(255,60,0,0.22)',     orb2:'rgba(255,140,0,0.18)',   accent:'#ff8c00', accentRgb:'255,140,0' },
      forest:   { orb1:'rgba(0,120,60,0.25)',     orb2:'rgba(10,200,100,0.18)',  accent:'#0ac864', accentRgb:'10,200,100' },
    };

    function hexToRgb(hex) {
      const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
      return `${r},${g},${b}`;
    }

    function setVar(name, value) {
      document.documentElement.style.setProperty(name, value);
    }

    function applyVars(vars) {
      Object.entries(vars).forEach(([k, v]) => setVar(k, v));
    }

    function saveTheme() {
      const props = ['--clr-accent','--clr-accent-rgb','--clr-pass','--clr-pass-rgb','--clr-fail','--clr-fail-rgb','--clr-warn','--clr-warn-rgb','--bg-orb1','--bg-orb2'];
      const saved = {};
      const cs = getComputedStyle(document.documentElement);
      props.forEach(p => { saved[p] = document.documentElement.style.getPropertyValue(p) || cs.getPropertyValue(p).trim(); });
      localStorage.setItem('dmarc-theme', JSON.stringify(saved));
    }

    function applyPreset(name) {
      const t = PRESET_THEMES[name];
      if (!t) return;
      setVar('--bg-orb1', t.orb1);
      setVar('--bg-orb2', t.orb2);
      setVar('--clr-accent', t.accent);
      setVar('--clr-accent-rgb', t.accentRgb);
      document.getElementById('pickAccent').value = t.accent;
      localStorage.setItem('dmarc-active-theme', name);
      saveTheme();
      updateSwatchActive(name);
    }

    function applyCustomColor(key, hex) {
      const rgb = hexToRgb(hex);
      setVar(`--clr-${key}`, hex);
      setVar(`--clr-${key}-rgb`, rgb);
      localStorage.removeItem('dmarc-active-theme');
      updateSwatchActive(null);
      saveTheme();
    }

    function resetTheme() {
      localStorage.removeItem('dmarc-theme');
      localStorage.removeItem('dmarc-active-theme');
      const DEFAULTS = {
        '--clr-accent':'#0a84ff','--clr-accent-rgb':'10,132,255',
        '--clr-pass':'#30d158','--clr-pass-rgb':'48,209,88',
        '--clr-fail':'#ff453a','--clr-fail-rgb':'255,69,58',
        '--clr-warn':'#ff9f0a','--clr-warn-rgb':'255,159,10',
        '--bg-orb1':'rgba(94,60,255,0.22)','--bg-orb2':'rgba(10,132,255,0.18)',
      };
      applyVars(DEFAULTS);
      syncPickerValues();
      updateSwatchActive('cosmic');
    }

    function syncPickerValues() {
      const cs = getComputedStyle(document.documentElement);
      const get = v => (document.documentElement.style.getPropertyValue(v) || cs.getPropertyValue(v)).trim();
      const clamp = v => v.startsWith('#') ? v : '#0a84ff'; // fallback if rgb()
      ['accent','pass','fail','warn'].forEach(k => {
        const el = document.getElementById('pick' + k.charAt(0).toUpperCase() + k.slice(1));
        if (el) { try { el.value = get(`--clr-${k}`); } catch(e) {} }
      });
    }

    function updateSwatchActive(name) {
      document.querySelectorAll('.theme-swatch').forEach(s => s.classList.toggle('active', s.dataset.theme === name));
    }

    // Init on load
    (function () {
      const active = localStorage.getItem('dmarc-active-theme');
      updateSwatchActive(active || 'cosmic');
      syncPickerValues();
    })();

    // ── Fetch ───────────────────────────────────────────────────────────────
    async function triggerFetch() {
      const btn = document.getElementById('fetchBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Fetching…';
      try {
        const r = await fetch('/fetch', { method: 'POST' });
        if (r.status === 401) { window.location = '/auth/login'; return; }
        const d = await r.json();
        if (d.error) alert('Error: ' + d.error);
        else { alert('Stored ' + d.stored + ' new report(s).'); location.reload(); }
      } catch(e) { alert('Request failed.'); }
      finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-arrow-clockwise me-1"></i>Fetch now';
      }
    }

    // Helper for other pages to read CSS vars for chart colors
    function cssClr(varName, alpha) {
      const rgb = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
      return alpha !== undefined ? `rgba(${rgb},${alpha})` : `rgb(${rgb})`;
    }
  </script>
</body>
</html>
