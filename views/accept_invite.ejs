<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Accept invitation — DMARC Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <style>
    body {
      background:
        radial-gradient(ellipse 70% 55% at 12% 10%, rgba(94,60,255,.22) 0%, transparent 65%),
        radial-gradient(ellipse 55% 45% at 88% 85%, rgba(10,132,255,.18) 0%, transparent 65%),
        #000;
      background-attachment: fixed;
      color: rgba(255,255,255,.88);
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .invite-card {
      background: rgba(255,255,255,.06);
      backdrop-filter: blur(28px) saturate(180%);
      -webkit-backdrop-filter: blur(28px) saturate(180%);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 22px;
      box-shadow: 0 8px 48px rgba(0,0,0,.55), inset 0 1px 0 rgba(255,255,255,.07);
      width: 100%;
      max-width: 420px;
      padding: 36px 32px;
    }
    .form-control {
      background: rgba(255,255,255,.07);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 10px;
      color: rgba(255,255,255,.92);
      transition: border-color .15s, box-shadow .15s;
    }
    .form-control:focus {
      background: rgba(255,255,255,.1);
      border-color: rgba(48,209,88,.7);
      box-shadow: 0 0 0 3px rgba(48,209,88,.18);
      color: #fff;
    }
    .form-control::placeholder { color: rgba(255,255,255,.25); }
    .form-label { color: rgba(255,255,255,.65); font-size: .85rem; font-weight: 500; }
    .btn-activate {
      background: linear-gradient(145deg, #38d968, #28b855);
      border: none;
      border-radius: 11px;
      color: #fff;
      font-weight: 600;
      font-size: .95rem;
      padding: .62rem 1.5rem;
      width: 100%;
      transition: box-shadow .15s;
    }
    .btn-activate:hover { box-shadow: 0 4px 20px rgba(48,209,88,.4); color: #fff; }
  </style>
</head>
<body>
  <div class="invite-card">
    <div class="text-center mb-4">
      <div style="font-size:2rem;margin-bottom:8px;"><i class="bi bi-shield-check" style="color:#30d158;"></i></div>
      <h5 class="fw-bold mb-1">DMARC Dashboard</h5>
      <% if (token) { %>
      <p class="text-secondary small mb-0">Welcome, <strong style="color:rgba(255,255,255,.8);"><%= username %></strong>. Set a password to activate your account.</p>
      <% } else { %>
      <p class="text-secondary small mb-0">Activate your account</p>
      <% } %>
    </div>

    <% if (error) { %>
    <div class="d-flex align-items-start gap-2 mb-3 p-3" style="background:rgba(255,69,58,.1);border:1px solid rgba(255,69,58,.25);border-radius:10px;font-size:.875rem;color:#ff453a;">
      <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1"></i>
      <span><%= error %></span>
    </div>
    <% } %>

    <% if (token) { %>
    <form method="post" action="/auth/accept-invite" autocomplete="off">
      <input type="hidden" name="token" value="<%= token %>" />
      <div class="mb-3">
        <label class="form-label">New password</label>
        <input type="password" name="password" class="form-control" placeholder="Minimum 8 characters" minlength="8" required autofocus />
      </div>
      <div class="mb-4">
        <label class="form-label">Confirm password</label>
        <input type="password" name="confirmPassword" class="form-control" placeholder="Repeat password" minlength="8" required />
      </div>
      <button type="submit" class="btn btn-activate">
        <i class="bi bi-check-lg me-2"></i>Activate account
      </button>
    </form>
    <% } else { %>
    <div class="text-center mt-2">
      <a href="/auth/login" class="text-secondary small">Back to sign in</a>
    </div>
    <% } %>
  </div>
</body>
</html>
