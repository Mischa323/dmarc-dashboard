<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="mb-0 fw-bold">Users &amp; Groups</h4>
  <button class="btn btn-sm btn-outline-success" type="button" data-bs-toggle="collapse" data-bs-target="#addLocalUser">
    <i class="bi bi-person-plus me-1"></i>Add local user
  </button>
</div>

<% if (flash) { %>
<div class="alert alert-success alert-dismissible py-2 mb-3">
  <i class="bi bi-check-circle me-1"></i><%= flash %>
  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
</div>
<% } %>

<!-- Add local user form -->
<div class="collapse mb-4" id="addLocalUser">
  <div class="card p-4">
    <h6 class="fw-semibold mb-1">New local user</h6>
    <% if (mailConfigured) { %>
    <p class="text-secondary small mb-3">Leave the password fields empty and provide an email address to send the user an invite link instead.</p>
    <% } %>
    <% if (locals.error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3">
      <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i><span><%= error %></span>
    </div>
    <% } %>
    <form method="post" action="/admin/local-users" autocomplete="off">
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label small fw-medium">Username</label>
          <input type="text" name="username" class="form-control form-control-sm"
                 style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:rgba(255,255,255,.9);"
                 placeholder="username" minlength="3" required />
        </div>
        <div class="col-md-3">
          <label class="form-label small fw-medium">Email</label>
          <input type="email" name="email" id="newUserEmail" class="form-control form-control-sm"
                 style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:rgba(255,255,255,.9);"
                 placeholder="user@example.com" oninput="togglePasswordFields()" />
        </div>
        <div class="col-md-2">
          <label class="form-label small fw-medium">Role</label>
          <select name="role" class="form-select form-select-sm"
                  style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:rgba(255,255,255,.9);">
            <option value="viewer">viewer</option>
            <option value="admin">admin</option>
          </select>
        </div>
        <div id="passwordFields" class="col-12">
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label small fw-medium">Password <% if (mailConfigured) { %><span class="text-secondary fw-normal">(or send invite)</span><% } %></label>
              <input type="password" name="password" id="newUserPassword" class="form-control form-control-sm"
                     style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:rgba(255,255,255,.9);"
                     placeholder="min 8 characters" minlength="8" />
            </div>
            <div class="col-md-3">
              <label class="form-label small fw-medium">Confirm password</label>
              <input type="password" name="confirmPassword" class="form-control form-control-sm"
                     style="background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.1);color:rgba(255,255,255,.9);"
                     placeholder="repeat password" minlength="8" />
            </div>
          </div>
        </div>
        <div class="col-12 d-flex align-items-center gap-2">
          <button type="submit" id="addUserBtn" class="btn btn-sm btn-success">
            <i class="bi bi-person-plus me-1"></i><span id="addUserBtnLabel">Add user</span>
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Local users -->
<h6 class="text-secondary small fw-semibold text-uppercase mb-2" style="letter-spacing:.05em;">
  <i class="bi bi-person-fill me-1"></i>Local users (<%= localUsers.length %>)
</h6>
<div class="card mb-4">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>2FA</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const u of localUsers) { %>
        <tr>
          <td class="fw-semibold small">
            <i class="bi bi-person-circle me-1 text-secondary"></i><%= u.username %>
            <% if (u.role === 'local_admin') { %>
            <span class="badge ms-1" style="background:rgba(255,214,10,.1);color:#ffd60a;border:1px solid rgba(255,214,10,.2);font-size:.7rem;">local admin</span>
            <% } else if (u.invite_pending) { %>
            <span class="badge ms-1" style="background:rgba(255,159,10,.1);color:#ff9f0a;border:1px solid rgba(255,159,10,.2);font-size:.7rem;"><i class="bi bi-envelope me-1"></i>invite pending</span>
            <% } %>
          </td>
          <td class="small">
            <form method="post" action="/admin/local-users/<%= u.id %>/email" class="d-flex align-items-center gap-1">
              <input type="email" name="email" value="<%= u.email || '' %>"
                     class="form-control form-control-sm" style="min-width:180px;background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.08);color:rgba(255,255,255,.8);"
                     placeholder="not set" />
              <button type="submit" class="btn btn-sm btn-outline-secondary px-2" title="Save email">
                <i class="bi bi-check-lg"></i>
              </button>
            </form>
          </td>
          <td class="small text-secondary">
            <% if (u.role === 'local_admin') { %>
            <span class="badge" style="background:rgba(255,214,10,.1);color:#ffd60a;border:1px solid rgba(255,214,10,.2);">local_admin</span>
            <% } else { %>
            <span class="text-secondary">via groups</span>
            <% } %>
          </td>
          <td class="small">
            <% if (u.role === 'local_admin') { %>
              <% if (u.totp_enabled) { %>
              <span class="text-success"><i class="bi bi-shield-check me-1"></i>enabled</span>
              <% } else { %>
              <span class="text-secondary">disabled</span>
              <% } %>
            <% } else { %>
            <span class="text-secondary">—</span>
            <% } %>
          </td>
          <td class="small text-secondary"><%= u.created_at ? u.created_at.slice(0, 10) : '—' %></td>
          <td class="text-end">
            <div class="d-flex gap-1 justify-content-end">
              <% if (u.invite_pending && u.email) { %>
              <button class="btn btn-sm btn-outline-secondary" onclick="resendInvite(<%= u.id %>, this)" title="Resend invite email">
                <i class="bi bi-envelope-arrow-up me-1"></i>Resend invite
              </button>
              <% } %>
              <% if (u.role !== 'local_admin') { %>
              <form method="post" action="/admin/local-users/<%= u.id %>/delete"
                    onsubmit="return confirm('Delete user \'<%= u.username %>\'?')">
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
              <% } %>
            </div>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- SSO users -->
<div class="d-flex align-items-center justify-content-between mb-2">
  <h6 class="text-secondary small fw-semibold text-uppercase mb-0" style="letter-spacing:.05em;">
    <i class="bi bi-microsoft me-1"></i>SSO users (<%= ssoUsers.length %>)
  </h6>
  <% if (ssoTenants.length > 0) { %>
  <div class="d-flex align-items-center gap-2">
    <span class="text-secondary" style="font-size:.78rem;">Import from Azure AD:</span>
    <% for (const t of ssoTenants) { %>
    <button class="btn btn-sm btn-outline-secondary" onclick="importAzureUsers(<%= t.id %>, '<%= t.name.replace(/'/g, '\\\'') %>', this)">
      <i class="bi bi-cloud-download me-1"></i><%= t.name %>
    </button>
    <% } %>
    <div id="importResult" style="display:none;"></div>
  </div>
  <% } %>
</div>
<div class="form-text mb-3" style="margin-top:-4px;">Import pre-populates users so they can be added to security groups before their first login. Requires <code>User.Read.All</code> Application permission in Azure.</div>

<% if (ssoUsers.length === 0) { %>
<div class="card p-4 text-center text-secondary">
  <i class="bi bi-people mb-3" style="font-size:2rem;"></i>
  <p class="mb-0 small">No SSO users yet. Users are created automatically on first Microsoft login.</p>
</div>
<% } else { %>
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th>User</th>
          <th>Tenant</th>
          <th>Role</th>
          <th>Last login</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const u of ssoUsers) { %>
        <tr>
          <td>
            <div class="fw-semibold small"><%= u.display_name || u.email %></div>
            <div class="text-secondary" style="font-size:.8rem;"><%= u.email %></div>
          </td>
          <td class="small text-secondary"><%= u.tenant_name || '—' %></td>
          <td class="small text-secondary">via groups</td>
          <td class="small text-secondary"><%= u.last_login ? u.last_login.slice(0, 16).replace('T', ' ') : 'Never' %></td>
          <td class="text-end">
            <form method="post" action="/admin/users/<%= u.id %>/delete"
                  onsubmit="return confirm('Remove <%= u.email %>?')">
              <button class="btn btn-sm btn-outline-danger">Remove</button>
            </form>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<div class="card mt-4 p-3">
  <h6 class="text-secondary small mb-2 fw-semibold text-uppercase" style="letter-spacing:.05em">Roles</h6>
  <div class="row g-2 small text-secondary">
    <div class="col-md-4"><strong class="text-light">local_admin</strong> — full access including 2FA and danger zone. Created during setup.</div>
    <div class="col-md-4"><strong class="text-light">admin</strong> — full access including tenant/user management. Set per group.</div>
    <div class="col-md-4"><strong class="text-light">viewer</strong> — read-only access to dashboard and reports. Set per group.</div>
  </div>
</div>

<!-- Security Groups -->
<div class="d-flex align-items-center mt-5 mb-3 gap-3">
  <h5 class="mb-0 fw-bold">Security Groups</h5>
  <a href="/admin/email-reports/new" class="btn btn-sm btn-success ms-auto">
    <i class="bi bi-plus-lg me-1"></i>Add group
  </a>
</div>

<% if (emailGroups.length === 0) { %>
<div class="card p-4 text-center text-secondary">
  <i class="bi bi-people mb-2" style="font-size:1.6rem;"></i>
  <p class="mb-2 small">No groups configured yet.</p>
  <a href="/admin/email-reports/new" class="btn btn-sm btn-success">Create first group</a>
</div>
<% } else { %>
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead>
        <tr>
          <th>Name</th>
          <th>Role</th>
          <th>Tenants</th>
          <th>Users</th>
          <th>Schedule</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const g of emailGroups) { %>
        <tr id="er-row-<%= g.id %>">
          <td class="fw-semibold small"><%= g.name %></td>
          <td class="small">
            <% if (g.role === 'admin') { %>
            <span class="badge" style="background:rgba(255,159,10,.12);color:#ff9f0a;border:1px solid rgba(255,159,10,.22);">admin</span>
            <% } else { %>
            <span class="badge bg-secondary bg-opacity-25 text-secondary">viewer</span>
            <% } %>
          </td>
          <td class="small text-secondary"><%= g.tenant_count %></td>
          <td class="small text-secondary"><%= g.member_count %></td>
          <td class="small">
            <% if (g.schedule === 'daily') { %>
            <span class="badge" style="background:rgba(10,132,255,.12);color:#0a84ff;border:1px solid rgba(10,132,255,.22);">Daily</span>
            <% } else if (g.schedule === 'weekly') { %>
            <span class="badge" style="background:rgba(48,209,88,.12);color:#30d158;border:1px solid rgba(48,209,88,.22);">Weekly</span>
            <% } else if (g.schedule === 'monthly') { %>
            <span class="badge" style="background:rgba(255,159,10,.12);color:#ff9f0a;border:1px solid rgba(255,159,10,.22);">Monthly</span>
            <% } else if (g.schedule === 'both') { %>
            <span class="badge" style="background:rgba(191,90,242,.12);color:#bf5af2;border:1px solid rgba(191,90,242,.22);">Daily + Weekly</span>
            <% } else { %>
            <span class="badge bg-secondary bg-opacity-25 text-secondary">Disabled</span>
            <% } %>
          </td>
          <td class="text-end" style="min-width:240px;">
            <div class="d-flex gap-1 justify-content-end flex-wrap">
              <button class="btn btn-sm btn-outline-secondary" onclick="erSendNow(<%= g.id %>, 'daily')">
                <i class="bi bi-send me-1"></i>Daily
              </button>
              <button class="btn btn-sm btn-outline-secondary" onclick="erSendNow(<%= g.id %>, 'weekly')">
                <i class="bi bi-send me-1"></i>Weekly
              </button>
              <button class="btn btn-sm btn-outline-secondary" onclick="erSendNow(<%= g.id %>, 'monthly')">
                <i class="bi bi-send me-1"></i>Monthly
              </button>
              <a href="/admin/email-reports/<%= g.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
              <form method="post" action="/admin/email-reports/<%= g.id %>/delete" class="d-inline"
                    onsubmit="return confirm('Delete \'<%= g.name %>\'?')">
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <tr id="er-result-row-<%= g.id %>" style="display:none;">
          <td colspan="6" class="pt-0 pb-2 px-3">
            <div id="er-result-<%= g.id %>" class="rounded p-2 small"></div>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<script>
  <% if (mailConfigured) { %>
  function togglePasswordFields() {
    const email = document.getElementById('newUserEmail').value.trim();
    const pwd   = document.getElementById('newUserPassword');
    const btn   = document.getElementById('addUserBtnLabel');
    if (email) {
      pwd.removeAttribute('required');
      btn.textContent = pwd.value ? 'Add user' : 'Send invite';
    } else {
      pwd.setAttribute('required', '');
      btn.textContent = 'Add user';
    }
  }
  document.getElementById('newUserPassword').addEventListener('input', () => {
    document.getElementById('addUserBtnLabel').textContent = document.getElementById('newUserPassword').value ? 'Add user' : (document.getElementById('newUserEmail').value.trim() ? 'Send invite' : 'Add user');
  });
  <% } %>

  async function resendInvite(id, btn) {
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';
    const r = await fetch('/admin/local-users/' + id + '/resend-invite', { method: 'POST' });
    const d = await r.json();
    btn.disabled = false;
    btn.innerHTML = orig;
    if (d.ok) { btn.style.color = 'var(--bs-success)'; setTimeout(() => btn.style.color = '', 2000); }
    else alert('Error: ' + d.error);
  }

  async function importAzureUsers(tenantId, tenantName, btn) {
    const result = document.getElementById('importResult');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + tenantName;
    result.style.display = 'none';
    try {
      const r = await fetch('/admin/tenants/' + tenantId + '/import-users', { method: 'POST' });
      const d = await r.json();
      result.style.display = '';
      if (d.ok) {
        const parts = [`${d.added} added`, `${d.updated} updated`];
        if (d.removed > 0) parts.push(`${d.removed} removed`);
        result.innerHTML = `<span class="small" style="color:#30d158;"><i class="bi bi-check-circle me-1"></i>${tenantName}: ${parts.join(', ')}. Reloading…</span>`;
        setTimeout(() => location.reload(), 1500);
      } else {
        result.innerHTML = `<div class="d-flex align-items-start gap-2 mt-2 p-3" style="background:rgba(255,69,58,.08);border:1px solid rgba(255,69,58,.25);border-radius:10px;max-width:540px;">
          <i class="bi bi-exclamation-triangle-fill flex-shrink-0 mt-1" style="color:#ff453a;font-size:.9rem;"></i>
          <span class="small" style="color:#ff453a;">${escHtml(d.error)}</span>
        </div>`;
      }
    } catch {
      result.style.display = '';
      result.innerHTML = `<span class="small" style="color:#ff453a;"><i class="bi bi-exclamation-triangle me-1"></i>Request failed.</span>`;
    }
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-cloud-download me-1"></i>' + tenantName;
  }

  async function erSendNow(id, period) {
    const row    = document.getElementById('er-result-row-' + id);
    const result = document.getElementById('er-result-' + id);
    result.style.cssText = 'background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:10px;';
    result.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Sending…';
    row.style.display = '';
    try {
      const r = await fetch('/admin/email-reports/' + id + '/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'period=' + period,
      });
      const data = await r.json();
      if (data.error) {
        result.style.cssText = 'background:rgba(255,69,58,.07);border:1px solid rgba(255,69,58,.2);border-radius:10px;';
        result.innerHTML = '<i class="bi bi-x-circle-fill me-2" style="color:#ff453a;"></i><span style="color:#ff453a;">' + escHtml(data.error) + '</span>';
      } else if (data.skipped) {
        result.style.cssText = 'background:rgba(255,159,10,.07);border:1px solid rgba(255,159,10,.2);border-radius:10px;';
        result.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2" style="color:#ff9f0a;"></i><span style="color:#ff9f0a;">Skipped — ' + escHtml(data.reason) + '</span>';
      } else {
        result.style.cssText = 'background:rgba(48,209,88,.07);border:1px solid rgba(48,209,88,.2);border-radius:10px;';
        result.innerHTML = '<i class="bi bi-check-circle-fill me-2" style="color:#30d158;"></i><span style="color:#30d158;">' + period + ' report sent to ' + data.recipients + ' recipient(s).</span>';
      }
    } catch (e) {
      result.style.cssText = 'background:rgba(255,69,58,.07);border:1px solid rgba(255,69,58,.2);border-radius:10px;';
      result.innerHTML = '<i class="bi bi-x-circle-fill me-2" style="color:#ff453a;"></i><span style="color:#ff453a;">' + escHtml(e.message) + '</span>';
    }
  }
  function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>

<% if (locals.error) { %>
<script>
  const el = document.getElementById('addLocalUser');
  if (el) new bootstrap.Collapse(el, { show: true });
</script>
<% } %>
