<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sign in — DMARC Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <style>
    body {
      background:
        radial-gradient(ellipse 70% 55% at 12% 10%, rgba(94, 60, 255, 0.22) 0%, transparent 65%),
        radial-gradient(ellipse 55% 45% at 88% 85%, rgba(10, 132, 255, 0.18) 0%, transparent 65%),
        #000;
      background-attachment: fixed;
      color: rgba(255,255,255,.88);
      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      background: rgba(255,255,255,.06);
      backdrop-filter: blur(28px) saturate(180%);
      -webkit-backdrop-filter: blur(28px) saturate(180%);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 22px;
      box-shadow: 0 8px 48px rgba(0,0,0,.55), inset 0 1px 0 rgba(255,255,255,.07);
      max-width: 420px;
      width: 100%;
      padding: 2.5rem;
    }
    .form-control {
      background: rgba(255,255,255,.07);
      border-color: rgba(255,255,255,.1);
      color: rgba(255,255,255,.9);
      border-radius: 10px;
    }
    .form-control:focus {
      background: rgba(255,255,255,.1);
      border-color: rgba(10,132,255,.7);
      color: rgba(255,255,255,.95);
      box-shadow: 0 0 0 3px rgba(10,132,255,.18);
    }
    .form-control::placeholder { color: rgba(255,255,255,.25); }
    .form-check-input { background-color: rgba(255,255,255,.09); border-color: rgba(255,255,255,.2); }
    .form-check-input:checked { background-color: #0a84ff; border-color: #0a84ff; }
    .form-check-label { color: rgba(255,255,255,.5); font-size: .83rem; }
    .divider { display: flex; align-items: center; gap: .75rem; color: rgba(255,255,255,.3); font-size: .8rem; margin: 1.25rem 0; }
    .divider::before, .divider::after { content: ''; flex: 1; border-top: 1px solid rgba(255,255,255,.08); }
    .btn-ms {
      background: rgba(10,132,255,.1);
      border: 1px solid rgba(10,132,255,.25);
      color: rgba(255,255,255,.85);
      display: flex;
      align-items: center;
      gap: .6rem;
      justify-content: center;
      width: 100%;
      padding: .55rem 1rem;
      border-radius: 10px;
      text-decoration: none;
      font-size: .88rem;
      transition: background .15s, border-color .15s;
    }
    .btn-ms:hover { background: rgba(10,132,255,.18); border-color: rgba(10,132,255,.4); color: #fff; }
    .ms-logo { width: 18px; height: 18px; flex-shrink: 0; }
    .btn-outline-secondary {
      background: rgba(255,255,255,.05);
      border-color: rgba(255,255,255,.13);
      color: rgba(255,255,255,.65);
      border-radius: 10px;
    }
    .btn-outline-secondary:hover { background: rgba(255,255,255,.1); color: rgba(255,255,255,.9); }
    .alert-danger { background: rgba(255,69,58,.1); border: 1px solid rgba(255,69,58,.22); color: #ff453a; border-radius: 12px; }
    .text-secondary { color: rgba(255,255,255,.42) !important; }
  </style>
</head>
<body>
  <div class="login-card m-3">
    <div class="text-center mb-4">
      <i class="bi bi-shield-check text-success" style="font-size:2rem;"></i>
      <h5 class="fw-bold mt-2 mb-0">DMARC Dashboard</h5>
    </div>

    <% if (error) { %>
    <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3">
      <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
      <span><%= error %></span>
    </div>
    <% } %>

    <!-- Local admin login -->
    <p class="text-secondary small fw-semibold mb-2 text-uppercase" style="letter-spacing:.05em;font-size:.72rem;">Administrator</p>
    <form method="post" action="/auth/local">
      <div class="mb-2">
        <input type="text" class="form-control form-control-sm" name="username"
               placeholder="Username" autocomplete="username" required />
      </div>
      <div class="mb-2">
        <input type="password" class="form-control form-control-sm" name="password"
               placeholder="Password" autocomplete="current-password" required />
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="rememberMe" name="rememberMe" value="1" />
        <label class="form-check-label small text-secondary" for="rememberMe">Stay logged in for 30 days</label>
      </div>
      <button type="submit" class="btn btn-outline-secondary w-100 btn-sm">
        <i class="bi bi-person-lock me-1"></i>Sign in locally
      </button>
    </form>

    <% if (tenants && tenants.length > 0) { %>
    <div class="divider">or sign in with Microsoft</div>

    <div class="d-flex flex-column gap-2 mb-2">
      <% for (const tenant of tenants) { %>
      <a href="/auth/sso/<%= tenant.id %>" class="btn-ms sso-btn" data-base="/auth/sso/<%= tenant.id %>">
        <svg class="ms-logo" viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg">
          <rect x="1" y="1" width="9" height="9" fill="#f25022"/>
          <rect x="11" y="1" width="9" height="9" fill="#7fba00"/>
          <rect x="1" y="11" width="9" height="9" fill="#00a4ef"/>
          <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
        </svg>
        Sign in with <%= tenant.name %>
      </a>
      <% } %>
    </div>
    <div class="form-check">
      <input class="form-check-input" type="checkbox" id="rememberMeSso" onchange="updateSsoLinks()" />
      <label class="form-check-label small text-secondary" for="rememberMeSso">Stay logged in for 30 days</label>
    </div>
    <% } %>

    <% if (!tenants || tenants.length === 0) { %>
    <p class="text-secondary text-center mt-3 mb-0" style="font-size:.8rem;">
      No SSO tenants configured yet.<br>Sign in as admin to add one.
    </p>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function updateSsoLinks() {
      const remember = document.getElementById('rememberMeSso').checked;
      document.querySelectorAll('.sso-btn').forEach(a => {
        a.href = a.dataset.base + (remember ? '?remember=1' : '');
      });
    }
  </script>
</body>
</html>
