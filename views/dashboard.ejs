<div class="d-flex align-items-center mb-4 gap-3">
  <h4 class="mb-0 fw-bold">Overview</h4>
  <select id="daysPicker" class="form-select form-select-sm w-auto" onchange="loadStats(this.value)">
    <option value="7">Last 7 days</option>
    <option value="30" selected>Last 30 days</option>
    <option value="90">Last 90 days</option>
    <option value="365">Last 12 months</option>
  </select>
  <small id="lastUpdated" class="text-secondary ms-auto"></small>
</div>

<!-- SPF-only pass warning -->
<div id="spfOnlyWarning" class="d-flex gap-3 mb-4" style="display:none!important;background:rgba(255,159,10,.1);border:1px solid rgba(255,159,10,.35);border-radius:12px;padding:16px 20px;">
  <div style="font-size:20px;line-height:1.3;">⚠</div>
  <div>
    <div class="fw-semibold mb-1" style="color:#ff9f0a;">DMARC passing via SPF only — no valid DKIM signatures found</div>
    <div class="small text-secondary" id="spfOnlyWarningText"></div>
  </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4" id="summaryCards">
  <% for (let i = 0; i < 6; i++) { %>
  <div class="col-6 col-md-4 col-xl-2">
    <div class="card p-3 stat-card text-center">
      <div class="text-secondary small mb-1 placeholder-glow"><span class="placeholder col-8"></span></div>
      <div class="display-6 placeholder-glow"><span class="placeholder col-6"></span></div>
    </div>
  </div>
  <% } %>
</div>

<!-- Charts row 1 -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card p-3 h-100">
      <h6 class="text-secondary mb-3">DMARC Result</h6>
      <div class="chart-container"><canvas id="resultPie"></canvas></div>
    </div>
  </div>
  <div class="col-md-8">
    <div class="card p-3 h-100">
      <h6 class="text-secondary mb-3">Daily message volume</h6>
      <div class="chart-container"><canvas id="trendLine"></canvas></div>
    </div>
  </div>
</div>

<!-- Charts row 2 -->
<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card p-3 h-100">
      <h6 class="text-secondary mb-3">Failure breakdown</h6>
      <div class="chart-container"><canvas id="failureDoughnut"></canvas></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card p-3 h-100">
      <h6 class="text-secondary mb-3">Top source IPs</h6>
      <div class="chart-container"><canvas id="ipBar"></canvas></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card p-3 h-100">
      <h6 class="text-secondary mb-3">Top reporting organisations</h6>
      <div class="chart-container"><canvas id="orgBar"></canvas></div>
    </div>
  </div>
</div>

<script>
let charts = {};

function destroyChart(id) {
  if (charts[id]) { charts[id].destroy(); delete charts[id]; }
}

function buildSummaryCards(s) {
  const passRate = s.pass_rate;
  const rateCard = passRate >= 98 ? 'card-pass' : passRate >= 90 ? 'card-warn' : 'card-fail';
  const rateColor = passRate >= 98 ? 'var(--clr-pass)' : passRate >= 90 ? 'var(--clr-warn)' : 'var(--clr-fail)';
  const clickStyle = 'cursor:pointer;';
  const nav = (url) => `onclick="location.href='${url}'"`;

  document.getElementById('summaryCards').innerHTML = `
    <div class="col-6 col-md-4 col-xl-2"><div class="card p-3 stat-card text-center" style="${clickStyle}" ${nav('/reports')} title="View all reports">
      <div class="text-secondary small mb-1">Reports</div>
      <div class="display-6">${s.total_reports}</div>
    </div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card p-3 stat-card text-center">
      <div class="text-secondary small mb-1">Total messages</div>
      <div class="display-6">${s.total_messages.toLocaleString()}</div>
    </div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card card-pass p-3 stat-card text-center" style="${clickStyle}" ${nav('/reports?status=pass')} title="View passing reports">
      <div class="small mb-1" style="color:rgba(var(--clr-pass-rgb),.65);">Passed</div>
      <div class="display-6 pass-color">${s.pass_count.toLocaleString()}</div>
    </div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card card-fail p-3 stat-card text-center" style="${clickStyle}" ${nav('/reports?status=fail')} title="View failing reports">
      <div class="small mb-1" style="color:rgba(var(--clr-fail-rgb),.65);">Failed</div>
      <div class="display-6 fail-color">${s.fail_count.toLocaleString()}</div>
    </div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card ${rateCard} p-3 stat-card text-center">
      <div class="small mb-1" style="color:${rateColor};opacity:.7;">Pass rate</div>
      <div class="display-6" style="color:${rateColor}">${s.pass_rate}%</div>
    </div></div>
    <div class="col-6 col-md-4 col-xl-2"><div class="card p-3 stat-card text-center">
      <div class="text-secondary small mb-1">Unique IPs</div>
      <div class="display-6">${s.unique_ips}</div>
    </div></div>`;
}

function buildResultPie(s) {
  destroyChart('resultPie');
  charts['resultPie'] = new Chart(document.getElementById('resultPie'), {
    type: 'doughnut',
    data: {
      labels: ['Pass', 'Fail'],
      datasets: [{
        data: [s.pass_count, s.fail_count],
        backgroundColor:      [cssClr('--clr-pass-rgb', .28), cssClr('--clr-fail-rgb', .28)],
        borderColor:          [cssClr('--clr-pass-rgb', .75), cssClr('--clr-fail-rgb', .75)],
        hoverBackgroundColor: [cssClr('--clr-pass-rgb', .45), cssClr('--clr-fail-rgb', .45)],
        borderWidth: 1.5,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,.55)', boxWidth: 12, padding: 14 } } },
      cutout: '65%',
      onClick(evt, elements) {
        if (!elements.length) return;
        const status = elements[0].index === 0 ? 'pass' : 'fail';
        location.href = '/reports?status=' + status;
      },
      onHover(evt, elements) { evt.native.target.style.cursor = elements.length ? 'pointer' : 'default'; }
    }
  });
}

function hexToRgba(hex, alpha) {
  if (!hex || !hex.startsWith('#')) return `rgba(10,132,255,${alpha})`;
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function glassBar(color, alpha = 0.22) {
  return {
    backgroundColor: hexToRgba(color, alpha),
    borderColor:     hexToRgba(color, 0.75),
    hoverBackgroundColor: hexToRgba(color, 0.38),
    borderWidth: 1.5,
    borderRadius: 4,
    borderSkipped: false,
  };
}

function glassCssBar(varName, alpha = 0.22) {
  return {
    backgroundColor: cssClr(varName, alpha),
    borderColor:     cssClr(varName, 0.72),
    hoverBackgroundColor: cssClr(varName, 0.38),
    borderWidth: 1.5,
    borderRadius: 4,
    borderSkipped: false,
  };
}

const glassScales = (stacked, horiz) => ({
  ...(horiz
    ? { x: { stacked, beginAtZero: true, grid: { color: 'rgba(255,255,255,.06)' }, ticks: { color: 'rgba(255,255,255,.38)', font: { size: 11 } } },
        y: { stacked, grid: { color: 'rgba(255,255,255,.04)' }, ticks: { color: 'rgba(255,255,255,.45)', font: { size: 11 } } } }
    : { x: { stacked, grid: { color: 'rgba(255,255,255,.04)' }, ticks: { color: 'rgba(255,255,255,.38)', font: { size: 11 } } },
        y: { stacked, beginAtZero: true, grid: { color: 'rgba(255,255,255,.06)' }, ticks: { color: 'rgba(255,255,255,.38)', font: { size: 11 } } } })
});

function buildTrendLine(trend, domainTrends, domainColors) {
  destroyChart('trendLine');
  const domains = Object.keys(domainTrends || {});
  let datasets;

  const multiDomain = domains.length > 1;
  if (multiDomain) {
    datasets = domains.map(domain => {
      const colorInfo = (domainColors || {})[domain] || {};
      const tenantClr = colorInfo.tenant || '#0a84ff';
      const domainClr = colorInfo.domain || tenantClr;
      return {
        label: domain,
        data: (domainTrends[domain] || []).map(d => d.pass + d.fail),
        ...glassBar(domainClr),
        stack: 'a',
        _tenantClr: tenantClr !== domainClr ? tenantClr : null,
        _domainClr: tenantClr !== domainClr ? domainClr : null,
      };
    });
  } else {
    datasets = [
      { label: 'Pass', ...glassCssBar('--clr-pass-rgb'), stack: 'a', data: trend.map(d => d.pass) },
      { label: 'Fail', ...glassCssBar('--clr-fail-rgb'), stack: 'a', data: trend.map(d => d.fail) },
    ];
  }

  const gradientPlugin = {
    id: 'domainGradient',
    beforeDatasetsDraw(chart) {
      const { ctx } = chart;
      chart.data.datasets.forEach((dataset, dsIdx) => {
        if (!dataset._tenantClr || !dataset._domainClr) return;
        const meta = chart.getDatasetMeta(dsIdx);
        if (!meta.visible) return;
        meta.data.forEach(bar => {
          const top    = Math.min(bar.y, bar.base);
          const bottom = Math.max(bar.y, bar.base);
          if (bottom - top < 1) return;
          const grad = ctx.createLinearGradient(0, top, 0, bottom);
          grad.addColorStop(0, hexToRgba(dataset._domainClr, 0.78));
          grad.addColorStop(1, hexToRgba(dataset._tenantClr, 0.35));
          bar.options.backgroundColor = grad;
          const hgrad = ctx.createLinearGradient(0, top, 0, bottom);
          hgrad.addColorStop(0, hexToRgba(dataset._domainClr, 0.92));
          hgrad.addColorStop(1, hexToRgba(dataset._tenantClr, 0.52));
          bar.options.hoverBackgroundColor = hgrad;
        });
      });
    }
  };

  const trendLabels = trend.map(d => d.date);

  charts['trendLine'] = new Chart(document.getElementById('trendLine'), {
    type: 'bar',
    data: { labels: trendLabels, datasets },
    plugins: [gradientPlugin],
    options: {
      responsive: true, maintainAspectRatio: false,
      scales: glassScales(true, false),
      plugins: { legend: { position: 'top', labels: { color: 'rgba(255,255,255,.55)', boxWidth: 12, padding: 14 } } },
      onClick(evt, elements) {
        if (!elements.length) return;
        const idx = elements[0].index;
        const date = trendLabels[idx];
        if (multiDomain) {
          const domain = datasets[elements[0].datasetIndex].label;
          location.href = '/reports?domain=' + encodeURIComponent(domain) + '&date=' + encodeURIComponent(date);
        } else {
          location.href = '/reports?date=' + encodeURIComponent(date);
        }
      },
      onHover(evt, elements) { evt.native.target.style.cursor = elements.length ? 'pointer' : 'default'; }
    }
  });
}

function buildFailureDoughnut(f) {
  destroyChart('failureDoughnut');
  charts['failureDoughnut'] = new Chart(document.getElementById('failureDoughnut'), {
    type: 'doughnut',
    data: {
      labels: ['DKIM + SPF fail', 'DKIM fail only', 'SPF fail only'],
      datasets: [{
        data: [f.dkim_and_spf, f.dkim_only, f.spf_only],
        backgroundColor: [cssClr('--clr-fail-rgb', .28), cssClr('--clr-warn-rgb', .28), cssClr('--clr-accent-rgb', .28)],
        borderColor:     [cssClr('--clr-fail-rgb', .75), cssClr('--clr-warn-rgb', .75), cssClr('--clr-accent-rgb', .75)],
        hoverBackgroundColor: [cssClr('--clr-fail-rgb', .45), cssClr('--clr-warn-rgb', .45), cssClr('--clr-accent-rgb', .45)],
        borderWidth: 1.5,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,.55)', boxWidth: 12, padding: 14 } } },
      cutout: '60%'
    }
  });
}

function buildIpBar(sources) {
  destroyChart('ipBar');
  const top = sources.slice(0, 10);
  const ipLabels = top.map(s => s.ip);
  charts['ipBar'] = new Chart(document.getElementById('ipBar'), {
    type: 'bar',
    data: {
      labels: ipLabels,
      datasets: [
        { label: 'Pass', data: top.map(s => s.pass), ...glassCssBar('--clr-pass-rgb'), stack: 'a' },
        { label: 'Fail', data: top.map(s => s.fail), ...glassCssBar('--clr-fail-rgb'), stack: 'a' }
      ]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      scales: glassScales(true, true),
      plugins: { legend: { position: 'top', labels: { color: 'rgba(255,255,255,.55)', boxWidth: 12, padding: 14 } } },
      onClick(evt, elements) {
        if (!elements.length) return;
        location.href = '/reports?ip=' + encodeURIComponent(ipLabels[elements[0].index]);
      },
      onHover(evt, elements) { evt.native.target.style.cursor = elements.length ? 'pointer' : 'default'; }
    }
  });
}

function buildOrgBar(orgs) {
  destroyChart('orgBar');
  const orgLabels = orgs.map(o => o.org);
  charts['orgBar'] = new Chart(document.getElementById('orgBar'), {
    type: 'bar',
    data: {
      labels: orgLabels,
      datasets: [
        { label: 'Pass', data: orgs.map(o => o.pass), ...glassCssBar('--clr-pass-rgb'), stack: 'a' },
        { label: 'Fail', data: orgs.map(o => o.fail), ...glassCssBar('--clr-fail-rgb'), stack: 'a' }
      ]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      scales: glassScales(true, true),
      plugins: { legend: { position: 'top', labels: { color: 'rgba(255,255,255,.55)', boxWidth: 12, padding: 14 } } },
      onClick(evt, elements) {
        if (!elements.length) return;
        location.href = '/reports?org=' + encodeURIComponent(orgLabels[elements[0].index]);
      },
      onHover(evt, elements) { evt.native.target.style.cursor = elements.length ? 'pointer' : 'default'; }
    }
  });
}

async function loadStats(days) {
  const res = await fetch('/api/stats?days=' + days);
  const data = await res.json();
  buildSummaryCards(data.summary);
  buildResultPie(data.summary);
  buildTrendLine(data.daily_trend, data.domain_trends, data.domain_colors);
  buildFailureDoughnut(data.failure_reasons);
  buildIpBar(data.top_sources);
  buildOrgBar(data.top_orgs);
  document.getElementById('lastUpdated').textContent = 'Updated ' + new Date().toLocaleTimeString();

  const spfOnly = data.summary.spf_only_pass || 0;
  const warn = document.getElementById('spfOnlyWarning');
  if (spfOnly > 0) {
    document.getElementById('spfOnlyWarningText').textContent =
      `${spfOnly.toLocaleString()} message${spfOnly !== 1 ? 's' : ''} passed DMARC because SPF alignment succeeded, but DKIM alignment failed. ` +
      `If SPF breaks (e.g. forwarded mail, cloud relay), these messages will fail DMARC entirely. Consider adding or fixing your DKIM configuration.`;
    warn.style.cssText = '';
  } else {
    warn.style.cssText = 'display:none!important;';
  }
}

loadStats(30);
</script>
