# Microsoft Entra (Azure AD) App Registration
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# The mailbox that receives DMARC reports (e.g. dmarc@yourdomain.com)
MAILBOX=dmarc@yourdomain.com
MAIL_FOLDER=Inbox

# How often to poll for new reports (minutes)
FETCH_INTERVAL_MINUTES=60

# OAuth2 callback (must match Azure app registration exactly)
REDIRECT_URI=https://localhost:3443/auth/callback

# Server
PORT=3443
DATABASE_URL=dmarc.db
